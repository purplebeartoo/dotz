# mpd basics 
mpd_connection_timeout = "5"
mpd_host = "localhost"
mpd_music_dir = "~/Music"
mpd_port = "6600"

# visualizer
visualizer_data_source = /tmp/mpd.fifo
visualizer_output_name = Visualizer
visualizer_in_stereo = yes
visualizer_autoscale = yes
visualizer_fps = 60
[[spectrum]]
visualizer_type = ellipse 
visualizer_look = "+|"
visualizer_color = blue, cyan, green, yellow, magenta, red
visualizer_spectrum_smooth_look = yes
visualizer_spectrum_dft_size = 4
visualizer_spectrum_gain = 20
visualizer_spectrum_hz_min = 20
visualizer_spectrum_hz_max = 20000

# colors
colors_enabled = "yes"
#active_window_border = "blue"
#alternative_ui_separator_color = "blue"
#color1 = "magenta"
#color2 = "magenta"
#empty_tag_color = "cyan"
header_window_color = "default"
main_window_color = "magenta"
progressbar_color = "magenta"
#state_flags_color = "magenta"
state_line_color = "blue"
statusbar_time_color = "blue"
statusbar_color = "blue"
volume_color = "blue"
#window_border_color = "magenta"

# misc
lyrics_directory = ~/.config/ncmpcpp/
playlist_disable_highlight_delay = 1
